                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  const order = body.order || body;",
                  "  pm.collectionVariables.set('order_id', order.ID || order.id);",
                  "  pm.test('Order created', () => pm.expect(order.ID || order.id).to.not.be.empty);",
                  "}"
                ]
              }
            }
          ],
