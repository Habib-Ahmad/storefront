{
  "info": {
    "name": "Storefront API",
    "description": "Full-flow testing: Auth \u2192 Tenant \u2192 Products \u2192 Variants \u2192 Orders \u2192 Wallet.\n\nSetup:\n1. Fill in supabase_url + supabase_anon_key in collection variables.\n2. Run \"Sign Up\" then \"Sign In\" (or just Sign In if already registered).\n3. Run \"Onboard Tenant\" once.\n4. Run remaining requests in order.\n\nThe collection auto-captures IDs so requests chain together.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8090"
    },
    {
      "key": "supabase_url",
      "value": ""
    },
    {
      "key": "supabase_anon_key",
      "value": ""
    },
    {
      "key": "admin_email",
      "value": "admin@acme.com"
    },
    {
      "key": "admin_password",
      "value": "password123"
    },
    {
      "key": "jwt",
      "value": ""
    },
    {
      "key": "user_id",
      "value": ""
    },
    {
      "key": "tenant_id",
      "value": ""
    },
    {
      "key": "product_id",
      "value": ""
    },
    {
      "key": "variant_id",
      "value": ""
    },
    {
      "key": "order_id",
      "value": ""
    },
    {
      "key": "image_id",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Supabase GoTrue auth. Sign up once, then sign in to get JWT.",
      "item": [
        {
          "name": "Sign Up",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('jwt', body.access_token);",
                  "  pm.collectionVariables.set('user_id', body.user.id);",
                  "  pm.test('Sign up successful', () => pm.expect(body.access_token).to.be.a('string'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "apikey",
                "value": "{{supabase_anon_key}}"
              }
            ],
            "url": "{{supabase_url}}/auth/v1/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            }
          }
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('jwt', body.access_token);",
                  "pm.collectionVariables.set('user_id', body.user.id);",
                  "pm.test('Sign in successful', () => pm.expect(body.access_token).to.be.a('string'));",
                  "pm.test('Has user id', () => pm.expect(body.user.id).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "apikey",
                "value": "{{supabase_anon_key}}"
              }
            ],
            "url": "{{supabase_url}}/auth/v1/token?grant_type=password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"password\": \"{{admin_password}}\"\n}"
            }
          }
        },
        {
          "name": "Auth Me",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has onboarded field', () => pm.expect(body).to.have.property('onboarded'));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/auth/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ]
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/health"
      }
    },
    {
      "name": "Tenants",
      "description": "Onboard \u2192 Get \u2192 Update Profile \u2192 Set Modules",
      "item": [
        {
          "name": "Onboard Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('tenant_id', body.ID || body.id);",
                  "  pm.test('Tenant created', () => pm.expect(body.Name || body.name).to.equal('Acme Store'));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{base_url}}/tenants/onboard",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Store\",\n  \"slug\": \"acme\",\n  \"admin_email\": \"{{admin_email}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.test('Tenant returned', () => pm.expect(body.ID || body.id).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/tenants/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              }
            ]
          }
        },
        {
          "name": "Update Profile",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/tenants/me",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Acme Store Updated\",\n  \"contact_email\": \"support@acme.com\",\n  \"contact_phone\": \"08012345678\",\n  \"address\": \"45 Bode Thomas, Surulere, Lagos\"\n}"
            }
          }
        },
        {
          "name": "Set Modules",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "url": "{{base_url}}/tenants/me/modules",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"inventory\": true,\n  \"payments\": true,\n  \"logistics\": false\n}"
            }
          }
        }
