#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"

# ── Backend ───────────────────────────────────────────────────────────────────
cd "$ROOT/backend"
go vet ./...
go test ./... -race -count=1

# ── Frontend: unit tests ──────────────────────────────────────────────────────
cd "$ROOT/client"
bun run test
