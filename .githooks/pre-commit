#!/bin/sh
set -e

ROOT="$(git rev-parse --show-toplevel)"

# ── Backend: gofmt ────────────────────────────────────────────────────────────
cd "$ROOT/backend"
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
    printf "Go files need formatting (run: cd backend && gofmt -w .):\n%s\n" "$unformatted"
    exit 1
fi

# ── Frontend: prettier ────────────────────────────────────────────────────────
cd "$ROOT/client"
bun prettier --check --ignore-unknown .
