# Copy to .env and fill in values.
# Never commit .env — it is gitignored.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
ENVIRONMENT=development

# ── Database ──────────────────────────────────────────────────────────────────
# Local (matches docker-compose.yml defaults):
DATABASE_URL=postgres://storefront:storefront@localhost:5432/storefront?sslmode=disable

# ── Security ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
HMAC_SECRET=

# ── Supabase Auth ─────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# ── Paystack ──────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=

# ── Logistics ─────────────────────────────────────────────────────────────────
TERMINAL_AFRICA_API_KEY=
SHIPBUBBLE_API_KEY=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=
